// RUN: %scale-test --begin 1 --end 12 --step 1 --select NumLeafScopes %s
// REQUIRES: asserts,no_asan

func test1(cond: Bool) {
    func compute(_: Int) {}

    compute(cond
       ? 1
%for i in range(1, N):
         + 1
%end
       : 1
%for i in range(1, N):
         * 1
%end
    )
}

func test2(cond: Bool) {
    func compute(_: UInt32) {}

    compute(cond
       ? 1
%for i in range(1, N):
         + 1
%end
       : 1
%for i in range(1, N):
         * 1
%end
    )
}

func test3(cond: Bool) {
