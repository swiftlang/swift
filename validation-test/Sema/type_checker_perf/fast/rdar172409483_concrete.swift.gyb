// RUN: %scale-test --begin 1 --end 7 --step 1 --select NumConstraintScopes %s
// REQUIRES: asserts,no_asan

struct Data: RangeReplaceableCollection, RandomAccessCollection {
  var startIndex: Int { return 0 }
  var endIndex: Int { return 0 }

  subscript(_: Int) -> UInt8 {
    get { return 0 }
    set {}
  }

  func replaceSubrange(_: Range<Int>, with: some Collection<UInt8>) {}

  static func + (_ lhs: Data, _ rhs: Data) -> Data { return lhs }
}

func test(x: Data) {
    let _ = x
%for i in range(0, N):
      + x
%end
}
