// RUN: %scale-test --begin 2 --end 10 --step 1 --select NumConstraintScopes %s
// REQUIRES: asserts,no_asan

struct C {
  let c: [C] = []
}

// The overloads of f() and g() are the same, except they are ordered differently.

extension Sequence {
  func f<T: Sequence>(_: (Element) -> T) -> [T.Element] {
    fatalError()
  }

  func f<T>(_: (Element) -> T?) -> [T] {
    fatalError()
  }
}

extension Sequence {
  func g<T>(_: (Element) -> T?) -> [T] {
    fatalError()
  }

  func g<T: Sequence>(_: (Element) -> T) -> [T.Element] {
    fatalError()
  }
}

func ff(_ c: [C]) -> [C] {
  return c
%for i in range(0, N):
    .f { $0.c }
%end
}

func gg(_ c: [C]) -> [C] {
  return c
%for i in range(0, N):
    .g { $0.c }
%end
}

