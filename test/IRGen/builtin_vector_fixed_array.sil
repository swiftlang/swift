// RUN: %target-swift-frontend -emit-ir -disable-availability-checking -enable-experimental-feature ValueGenerics -enable-experimental-feature BuiltinModule %s | %FileCheck %s
import Builtin
import Swift

sil @trivial_fixed: $@convention(thin) (Builtin.Vector<2, Int>) -> (Builtin.Vector<2, Int>, Builtin.Vector<2, Int>) {
entry(%v : $Builtin.Vector<2, Int>):
    %r = tuple (%v : $Builtin.Vector<2, Int>, %v : $Builtin.Vector<2, Int>)
    return %r : $(Builtin.Vector<2, Int>, Builtin.Vector<2, Int>)
}

sil @loadable_fixed: $@convention(thin) (@owned Builtin.Vector<2, AnyObject>) -> @owned (Builtin.Vector<2, AnyObject>, Builtin.Vector<2, AnyObject>) {
entry(%v : $Builtin.Vector<2, AnyObject>):
    retain_value %v : $Builtin.Vector<2, AnyObject>
    %r = tuple (%v : $Builtin.Vector<2, AnyObject>, %v : $Builtin.Vector<2, AnyObject>)
    return %r : $(Builtin.Vector<2, AnyObject>, Builtin.Vector<2, AnyObject>)
}

sil @loadable_fixed_indirect: $@convention(thin) (@in Builtin.Vector<420, AnyObject>) -> @out (Builtin.Vector<420, AnyObject>, Builtin.Vector<420, AnyObject>) {
entry(%r : $*(Builtin.Vector<420, AnyObject>, Builtin.Vector<420, AnyObject>), %v : $*Builtin.Vector<420, AnyObject>):
    %a = tuple_element_addr %r : $*(Builtin.Vector<420, AnyObject>, Builtin.Vector<420, AnyObject>), 0
    copy_addr %v to [init] %a: $*Builtin.Vector<420, AnyObject>
    %b = tuple_element_addr %r : $*(Builtin.Vector<420, AnyObject>, Builtin.Vector<420, AnyObject>), 1
    copy_addr [take] %v to [init] %b: $*Builtin.Vector<420, AnyObject>
    return undef : $()
}

struct Padded {
    var a: Int32
    var b: Int8
}

sil @loadable_padded_fixed: $@convention(thin) (Builtin.Vector<2, Padded>) -> (Builtin.Vector<2, Padded>, Builtin.Vector<2, Padded>) {
entry(%v : $Builtin.Vector<2, Padded>):
    %r = tuple (%v : $Builtin.Vector<2, Padded>, %v : $Builtin.Vector<2, Padded>)
    return %r : $(Builtin.Vector<2, Padded>, Builtin.Vector<2, Padded>)
}

