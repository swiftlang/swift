// Check that non-trivial owned pack-exploded parameters are loaded and passed correctly.
// CHECK-LABEL: sil [ossa] @call_copy_pack_class_c_inout : $@convention(thin) (@owned C) -> @owned C {
// CHECK: bb0([[IN_C:%[^,]+]] : @owned $C)
// CHECK: [[OUT_PACK:%[^,]+]] = alloc_pack $Pack{C}
// CHECK: [[IN_PACK:%[^,]+]] = alloc_pack $Pack{C}
// CHECK: store [[IN_C]] to [init] [[IN_ADDR:%[0-9]+]]
// CHECK: pack_element_set [[IN_ADDR]] into [[PACK_SET_IDX:%[^,]+]] of [[IN_PACK]]
// CHECK: [[IN_C_PACK_ADDR:%[^,]+]] = pack_element_get [[PACK_GET_IDX:%[^,]+]] of [[IN_PACK]] as $*C
// CHECK: [[SPECIALIZED:%[^,]+]] = function_ref @$s23copy_pack_class_c_inoutTf8xx_n : $@convention(thin) (@inout C) -> @owned C
// CHECK-NEXT: [[RESULT:%[^,]+]] = apply [[SPECIALIZED]]([[IN_C_PACK_ADDR]]) : $@convention(thin) (@inout C) -> @owned C
// CHECK-LABEL: } // end sil function 'call_copy_pack_class_c_inout'
sil [ossa] @call_copy_pack_class_c_inout : $@convention(thin) (@owned C) -> @owned C {
bb0(%c : @owned $C):
