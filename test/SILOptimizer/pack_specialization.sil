// MIXED RESULT CONVENTIONS TESTS:

// INTERLEAVING PACK AND NON-PACK ARGUMENTS TESTS:
//
// The new function arguments and return values corresponding to pack parameters
// are inserted into the parameter and results lists in the same order as they
// are passed in the original pack.
//
// Other tests cover the callee and call-site modifications necessary to extract
// elements from packs. These tests focus primarily on the positions of the
// mapped arguments and result values.

// CHECK-LABEL: sil shared [ossa] @$s14interleave_intTf8xnxn_n : $@convention(thin) (Builtin.Int64, Builtin.Int32, Builtin.Int64) -> (Builtin.Int64, Builtin.Int32, Builtin.Int64) {
// CHECK: bb0([[A1:%[^,]+]] : $Builtin.Int64, [[A2:%[^,]+]] : $Builtin.Int32, [[A3:%[^,]+]] : $Builtin.Int64):
// CHECK: [[IN_PACK:%[^,]+]] = alloc_pack $Pack{Builtin.Int32}
// CHECK: store [[A2]] to [trivial] [[IN_STACK:%[0-9]+]]
// CHECK: pack_element_set [[IN_STACK]] into [[IN_IDX:%[^,]+]] of [[IN_PACK]]
// CHECK: [[OUT_PACK:%[^,]+]] = alloc_pack $Pack{Builtin.Int32}
// CHECK: [[OUT_ADDR:%[^,]+]] = alloc_stack $Builtin.Int32
// CHECK: [[ORIGINAL_RESULT:%[^,]+]] = tuple ([[A1]], [[A3]])
// CHECK: ([[R1:%[^,]+]], [[R3:%[^,]+]]) = destructure_tuple [[ORIGINAL_RESULT]]
// CHECK: [[R2:%[^,]+]] = load [trivial] [[OUT_ADDR]]
// CHECK: [[RESULT:%[^,]+]] = tuple ([[R1]], [[R2]], [[R3]])
// CHECK: return [[RESULT]]
// CHECK-LABEL: } // end sil function '$s14interleave_intTf8xnxn_n'
sil [ossa] @interleave_int : $@convention(thin) (Int, @pack_guaranteed Pack{Builtin.Int32}, Int) -> (Int, @pack_out Pack{Builtin.Int32}, Int) {
bb0(%0 : $*Pack{Builtin.Int32}, %1 : $Int, %2 : $*Pack{Builtin.Int32}, %3 : $Int):
  %7 = scalar_pack_index 0 of $Pack{Builtin.Int32}
  %8 = pack_element_get %7 of %0 as $*Int
  %9 = pack_element_get %7 of %2 as $*Int
  copy_addr %9 to [init] %8
  %12 = tuple (%1, %3)
  return %12
}

sil [ossa] @call_interleave_int : $@convention(thin) () -> (Int, Builtin.Int32, Int) {
bb0:
  %0 = alloc_pack $Pack{Builtin.Int32}
  %1 = alloc_stack $Builtin.Int32
  %2 = scalar_pack_index 0 of $Pack{Builtin.Int32}
  pack_element_set %1 into %2 of %0
  %4 = integer_literal $Int, 1
  %6 = alloc_pack $Pack{Builtin.Int32}
  %7 = alloc_stack $Builtin.Int32
  %8 = integer_literal $Builtin.Int32, 2
  store %8 to [trivial] %7
  pack_element_set %7 into %2 of %6
  %12 = integer_literal $Int, 3
  %14 = function_ref @interleave_int : $@convention(thin) (Int, @pack_guaranteed Pack{Builtin.Int32}, Int) -> (Int, @pack_out Pack{Builtin.Int32}, Int)
  %15 = apply %14(%0, %4, %6, %12) : $@convention(thin) (Int, @pack_guaranteed Pack{Builtin.Int32}, Int) -> (Int, @pack_out Pack{Builtin.Int32}, Int)
  dealloc_stack %7
  dealloc_pack %6
  %18 = tuple_extract %15, 0
  %19 = tuple_extract %15, 1
  %20 = load [trivial] %1
  dealloc_stack %1
  dealloc_pack %0
  %23 = tuple (%18, %20, %19)
  return %23
}

sil [ossa] @interleave_c : $@convention(thin) (Int, @pack_guaranteed Pack{C}, Int) -> (Int, @pack_out Pack{C}, Int) {
bb0(%0 : $*Pack{C}, %1 : $Int, %2 : $*Pack{C}, %3 : $Int):
  %7 = scalar_pack_index 0 of $Pack{C}
  %8 = pack_element_get %7 of %0 as $*C
  %9 = pack_element_get %7 of %2 as $*C
  copy_addr %9 to [init] %8
