  store %instance to [init] %addr : $*C
  cond_br undef, bb2, bb3
bb2:
  destroy_addr %addr : $*C
  br bb5
bb3:
  destroy_addr %addr : $*C
  br bb5
bb4:
  destroy_value [dead_end] %instance
  br bb5
bb5:
  unreachable
}

