  br bb3

bb2:
  %5 = alloc_stack [lexical] $FakeOptional<Klass>
  %6 = store_borrow %2 to %5
  cond_br undef, bb8, bb9

bb3:
  cond_br undef, bb5, bb4

bb4:
  end_borrow %2
  destroy_value [dead_end] %1
