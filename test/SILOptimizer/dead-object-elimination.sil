// CHECK:       [[THROW_BLOCK]]:
// CHECK:         throw [[INSTANCE]] 
// CHECK:       [[REGULAR_BLOCK]]:
// CHECK:         destroy_value [[INSTANCE]] 
// CHECK:         [[RETVAL:%[^,]+]] = tuple ()
// CHECK:         return [[RETVAL]] 
// CHECK-LABEL: } // end sil function 'term_7'
