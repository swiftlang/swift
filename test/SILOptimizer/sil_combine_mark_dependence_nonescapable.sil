// RUN: %target-sil-opt -sil-print-types %s -sil-combine -enable-experimental-feature Lifetimes | %FileCheck %s

// REQUIRES: swift_in_compiler
// REQUIRES: swift_feature_Lifetimes

// Test that SILCombine does not remove mark_dependence [nonescaping] when the
// value type is non-escapable, even when the base is a trivial object.
//
// For non-escapable types, mark_dependence carries lifetime dependency
// information. Removing it when the base is trivial can lead to ownership
// violations after PredictableDeadAllocationElimination promotes a
// mark_dependence base from alloc_stack to a stored trivial value.
//
// See: https://github.com/swiftlang/swift/issues/88022

sil_stage canonical

import Swift
import Builtin

struct NE : ~Copyable, ~Escapable {}

// CHECK-LABEL: sil [ossa] @test_mark_dependence_nonescapable_trivial_base
// CHECK:         mark_dependence [nonescaping]
// CHECK-LABEL: } // end sil function 'test_mark_dependence_nonescapable_trivial_base'
sil [ossa] @test_mark_dependence_nonescapable_trivial_base : $@convention(thin) (@owned NE, Int) -> @owned NE {
bb0(%0 : @owned $NE, %1 : $Int):
  %2 = mark_dependence [nonescaping] %0 on %1
  return %2
}

// Verify that mark_dependence with a trivial base IS still removed for
// escapable types (the normal case).
//
// CHECK-LABEL: sil [ossa] @test_mark_dependence_escapable_trivial_base
// CHECK-NOT:     mark_dependence
// CHECK:         return
// CHECK-LABEL: } // end sil function 'test_mark_dependence_escapable_trivial_base'
sil [ossa] @test_mark_dependence_escapable_trivial_base : $@convention(thin) (@guaranteed AnyObject, Int) -> @owned AnyObject {
bb0(%0 : @guaranteed $AnyObject, %1 : $Int):
  %2 = copy_value %0
  %3 = mark_dependence %2 on %1
  return %3
}
