// RUN: not --crash %target-sil-opt -enable-sil-verify-all=true -sil-verify-all=true %s
// RUN: %target-sil-opt -enable-sil-verify-all=false -sil-verify-all=false %s

// We only run this test without asserts.

// UNSUPPORTED: asserts

// The wasi lit.site.cfg has LLVM_ENABLE_ASSERTIONS=FALSE, so `asserts` is
// not in available_features. But the macOS-arm64 asserts compiler is what
// actually runs the wasi tests, so the SIL verifier triggers anyway.
// UNSUPPORTED: OS=wasip1

class Klass {}

sil [ossa] @leaky_code : $@convention(thin) () -> () {
bb0:
  %0 = alloc_ref $Klass
  %9999 = tuple()
  return %9999 : $()
}
