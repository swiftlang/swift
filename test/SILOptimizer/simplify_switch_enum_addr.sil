// CHECK-LABEL: sil [ossa] @constant_fold_simple :
// CHECK:         inject_enum_addr %0
// CHECK-NEXT:    br bb1
// CHECK:       } // end sil function 'constant_fold_simple'
sil [ossa] @constant_fold_simple : $@convention(thin) () -> () {
bb0:
  %0 = alloc_stack $Optional<C>
  debug_value %0, let, name "e2", expr op_deref
  inject_enum_addr %0, #Optional.none!enumelt
  switch_enum_addr %0, case #Optional.some!enumelt: bb1, case #Optional.none!enumelt: bb2 

bb1:
  destroy_addr %0
  br bb3

bb2:
  br bb3

bb3:
  dealloc_stack %0
  %r = tuple ()
  return %r
}

// CHECK-LABEL: sil [ossa] @constant_fold_with_payload :
// CHECK:         inject_enum_addr %1
// CHECK-NEXT:    br bb1
// CHECK:       } // end sil function 'constant_fold_with_payload'
sil [ossa] @constant_fold_with_payload : $@convention(thin) (@owned C) -> () {
bb0(%0 : @owned $C):
  %1 = alloc_stack $Optional<C>
  %2 = init_enum_data_addr %1, #Optional.some!enumelt
  store %0 to [init] %2
  inject_enum_addr %1, #Optional.some!enumelt
  switch_enum_addr %1, case #Optional.some!enumelt: bb1, case #Optional.none!enumelt: bb2 

bb1:
  destroy_addr %1
  br bb3

bb2:
  br bb3

bb3:
  dealloc_stack %1
  %r = tuple ()
  return %r
}

// CHECK-LABEL: sil [ossa] @resilient_enum_case_propagation :
// CHECK-NOT:     switch_enum
// CHECK:       } // end sil function 'resilient_enum_case_propagation'
sil [ossa] @resilient_enum_case_propagation : $@convention(thin) () -> Builtin.Int64 {
bb0:
  %0 = alloc_stack $FloatingPointRoundingRule
  inject_enum_addr %0, #FloatingPointRoundingRule.toNearestOrEven!enumelt
  %2 = alloc_stack $FloatingPointRoundingRule
  copy_addr %0 to [init] %2
  destroy_addr %0
  switch_enum_addr %2, case #FloatingPointRoundingRule.toNearestOrAwayFromZero!enumelt: bb1, default bb2

bb1:
  %6 = integer_literal $Builtin.Int64, 1
  br bb3(%6)

bb2:
  destroy_addr %2
  %9 = integer_literal $Builtin.Int64, 0
  br bb3(%9)

bb3(%11 : $Builtin.Int64):
  dealloc_stack %2
  dealloc_stack %0
  return %11
}

