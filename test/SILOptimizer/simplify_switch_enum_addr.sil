// RUN: %target-sil-opt %s -simplification -simplify-instruction=switch_enum_addr | %FileCheck %s

import Swift
import Builtin

class C {}

class Klass {}

enum E {
  case a(C)
  case b(C)
  case c
}

enum E2 {
  case a
  case b
}

// CHECK-LABEL: sil [ossa] @unchecked_take_enum_data_addr_promotion : $@convention(thin) (@inout Optional<C>) -> () {
// CHECK:       bb0(%0 : $*Optional<C>):
// CHECK-NEXT:    %1 = load_borrow
// CHECK-NEXT:    switch_enum %1
// CHECK:       bb1([[PL:%.*]] : @guaranteed $C):
// CHECK-NEXT:     end_borrow %1
// CHECK-NEXT:     tuple
// CHECK:       bb2:
// CHECK-NEXT:     end_borrow %1
// CHECK-NEXT:     unreachable
// CHECK:       } // end sil function 'unchecked_take_enum_data_addr_promotion'
sil [ossa] @unchecked_take_enum_data_addr_promotion : $@convention(thin) (@inout Optional<C>) -> () {
bb0(%0 : $*Optional<C>):
  switch_enum_addr %0, case #Optional.some!enumelt: bb1, case #Optional.none!enumelt: bb2

bb1:
  %3 = tuple ()
  return %3

bb2:
  unreachable
}

