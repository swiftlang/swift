// CHECK-LABEL: sil [ossa] @test_redundantownedphiarg5 :
// CHECK: bb1([[ARG1:%.*]] : @owned $FakeOptional<Klass>, [[ARG2:%.*]] : @owned $FakeOptional<Klass>):
// CHECK-NOT: copy_value
// CHECK: bb3([[ARG3:%.*]] : @owned $FakeOptional<Klass>, [[ARG4:%.*]] : @owned $FakeOptional<Klass>):
// CHECK-NOT: copy_value
// CHECK-LABEL: } // end sil function 'test_redundantownedphiarg5'
sil [ossa] @test_redundantownedphiarg5 : $@convention(thin) () -> () {
bb0:
  %0 = enum $FakeOptional<Klass>, #FakeOptional.none!enumelt 
  cond_br undef, bb2, bb4

bb1(%3 : @owned $FakeOptional<Klass>, %4 : @owned $FakeOptional<Klass>):
  destroy_value %3 : $FakeOptional<Klass>
  destroy_value %4 : $FakeOptional<Klass>
  %res = tuple ()
  return %res : $()

bb2:
  br bb3(%0 : $FakeOptional<Klass>, %0 : $FakeOptional<Klass>)

bb3(%1 : @owned $FakeOptional<Klass>, %2 : @owned $FakeOptional<Klass>):
  br bb1(%1 : $FakeOptional<Klass>, %2 : $FakeOptional<Klass>)

bb4:
  br bb1(%0 : $FakeOptional<Klass>, %0 : $FakeOptional<Klass>)
}


// Both-owned phis are no longer collapsed, so both bb3 and bb4 keep both args.
// CHECK-LABEL: sil [ossa] @test_redundantownedphiarg6 :
// CHECK: bb3([[ARG1:%.*]] : @owned $FakeOptional<Klass>, [[ARG2:%.*]] : @owned $FakeOptional<Klass>):
// CHECK-NOT: copy_value
// CHECK: bb4([[ARG3:%.*]] : @owned $FakeOptional<Klass>, [[ARG4:%.*]] : @owned $FakeOptional<Klass>):
// CHECK-NOT: copy_value
// CHECK-LABEL: } // end sil function 'test_redundantownedphiarg6'
sil [ossa] @test_redundantownedphiarg6 : $@convention(thin) () -> () {
bb0:
  %0 = enum $FakeOptional<Klass>, #FakeOptional.none!enumelt 
  cond_br undef, bb1, bb2

bb1:
  br bb3(%0 : $FakeOptional<Klass>, %0 : $FakeOptional<Klass>)

bb2:
  br bb4(%0 : $FakeOptional<Klass>, %0 : $FakeOptional<Klass>)

bb3(%1 : @owned $FakeOptional<Klass>, %2 : @owned $FakeOptional<Klass>):
  br bb4(%1 : $FakeOptional<Klass>, %2 : $FakeOptional<Klass>)

bb4(%3 : @owned $FakeOptional<Klass>, %4 : @owned $FakeOptional<Klass>):
  destroy_value %3 : $FakeOptional<Klass>
  destroy_value %4 : $FakeOptional<Klass>
  %res = tuple ()
  return %res : $()
}

// CHECK-LABEL: sil [ossa] @test_redundantguaranteedphiarg1 :
// CHECK: bb3([[ARG1:%.*]] : @guaranteed $FakeOptional<Klass>, [[ARG2:%.*]] : @guaranteed $FakeOptional<Klass>):
// CHECK-LABEL: } // end sil function 'test_redundantguaranteedphiarg1'
sil [ossa] @test_redundantguaranteedphiarg1 : $@convention(thin) () -> () {
bb0:
  %0 = enum $FakeOptional<Klass>, #FakeOptional.none!enumelt
  cond_br undef, bb1, bb2

bb1:
  br bb3(%0, %0)

bb2:
  br bb3(%0, %0)

bb3(%4 : @guaranteed $FakeOptional<Klass>, %5 : @guaranteed $FakeOptional<Klass>):
  %6 = borrowed %5 from ()
  %7 = borrowed %4 from ()
  %8 = tuple ()
  return %8
}

// CHECK-LABEL: sil [ossa] @test_redundantguaranteedphiarg2 :
// CHECK: bb3([[ARG1:%.*]] : @owned $FakeOptional<Klass>, [[ARG2:%.*]] : @reborrow $FakeOptional<Klass>):
// CHECK-LABEL: } // end sil function 'test_redundantguaranteedphiarg2'
sil [ossa] @test_redundantguaranteedphiarg2 : $@convention(thin) () -> () {
bb0:
  %0 = enum $FakeOptional<Klass>, #FakeOptional.none!enumelt
  %1 = begin_borrow %0
  cond_br undef, bb1, bb2

bb1:
  br bb3(%0, %1)

bb2:
  br bb3(%0, %1)

bb3(%5 : @owned $FakeOptional<Klass>, %6 : @reborrow $FakeOptional<Klass>):
  %7 = borrowed %6 from ()
  end_borrow %7
  destroy_value %5
  %10 = tuple ()
  return %10
}

// CHECK-LABEL: sil [ossa] @test_redundantguaranteedphiarg3 :
// CHECK: bb3([[ARG3:%.*]] : @reborrow $FakeOptional<Klass>, [[ARG2:%.*]] : @reborrow $FakeOptional<Klass>):
// CHECK-LABEL: } // end sil function 'test_redundantguaranteedphiarg3'
sil [ossa] @test_redundantguaranteedphiarg3 : $@convention(thin) () -> () {
bb0:
  %0 = enum $FakeOptional<Klass>, #FakeOptional.none!enumelt
  %1 = begin_borrow %0
  %2 = begin_borrow %0
  cond_br undef, bb1, bb2

bb1:
  br bb3(%1, %2)

bb2:
  br bb3(%1, %2)

bb3(%6 : @reborrow $FakeOptional<Klass>, %7 : @reborrow $FakeOptional<Klass>):
  %8 = borrowed %7 from ()
  %9 = borrowed %6 from ()
  cond_br undef, bb4, bb5

bb4:
  end_borrow %9
  end_borrow %8
  br bb6

bb5:
  end_borrow %8
  end_borrow %9
  br bb6

bb6:
  %17 = tuple ()
  return %17
}

// Owned phis where a forwarding instruction wraps a none-ownership value.
// isIdenticalTo considers these structurally equal to the same enum without
// forwarding.

sil @callee : $@convention(thin) () -> ()

// Both phis are @owned wrapping a none-ownership thin_to_thick_function result).
// The enum instructions are structurally identical so valuesAreEqual returns true.
// However, we chose not to optimize this case because it requires creating
// a copy.
//
// CHECK-LABEL: sil [ossa] @both_owned_phis_from_forwarding_enum :
// CHECK: bb3([[A:%.*]] : @owned $Optional<@callee_guaranteed () -> ()>):
// CHECK-LABEL: } // end sil function 'both_owned_phis_from_forwarding_enum'
sil [ossa] @both_owned_phis_from_forwarding_enum : $@convention(thin) () -> () {
bb0:
  %fn = function_ref @callee : $@convention(thin) () -> ()
  %thick = thin_to_thick_function %fn to $@callee_guaranteed () -> ()
  cond_br undef, bb1, bb2

bb1:
  %some1 = enum $Optional<@callee_guaranteed () -> ()>, #Optional.some!enumelt, %thick, forwarding: @owned
  %some2 = enum $Optional<@callee_guaranteed () -> ()>, #Optional.some!enumelt, %thick, forwarding: @owned
  br bb3(%some1 : $Optional<@callee_guaranteed () -> ()>, %some2 : $Optional<@callee_guaranteed () -> ()>)

bb2:
  %none1 = enum $Optional<@callee_guaranteed () -> ()>, #Optional.none!enumelt
  %none2 = enum $Optional<@callee_guaranteed () -> ()>, #Optional.none!enumelt
  br bb3(%none1 : $Optional<@callee_guaranteed () -> ()>, %none2 : $Optional<@callee_guaranteed () -> ()>)

bb3(%phi1 : @owned $Optional<@callee_guaranteed () -> ()>, %phi2 : @owned $Optional<@callee_guaranteed () -> ()>):
  destroy_value %phi1 : $Optional<@callee_guaranteed () -> ()>
  destroy_value %phi2 : $Optional<@callee_guaranteed () -> ()>
  %r = tuple ()
  return %r : $()
}

// phi1 is @owned, phi2 is @none (receives a structurally
// identical enum without the forwarding override).
// The pass should collapse the @owned phi into the @none phi.
//
// CHECK-LABEL: sil [ossa] @owned_phi_from_forwarding_enum_wrapping_none :
// CHECK: bb3([[A:%.*]] : $Optional<@callee_guaranteed () -> ()>):
// CHECK-LABEL: } // end sil function 'owned_phi_from_forwarding_enum_wrapping_none'
sil [ossa] @owned_phi_from_forwarding_enum_wrapping_none : $@convention(thin) () -> () {
bb0:
  %fn = function_ref @callee : $@convention(thin) () -> ()
  %thick = thin_to_thick_function %fn to $@callee_guaranteed () -> ()
  cond_br undef, bb1, bb2

bb1:
  %some_owned = enum $Optional<@callee_guaranteed () -> ()>, #Optional.some!enumelt, %thick, forwarding: @owned
  %some_none = enum $Optional<@callee_guaranteed () -> ()>, #Optional.some!enumelt, %thick
  br bb3(%some_owned : $Optional<@callee_guaranteed () -> ()>, %some_none : $Optional<@callee_guaranteed () -> ()>)

bb2:
  %none1 = enum $Optional<@callee_guaranteed () -> ()>, #Optional.none!enumelt
  %none2 = enum $Optional<@callee_guaranteed () -> ()>, #Optional.none!enumelt
  br bb3(%none1 : $Optional<@callee_guaranteed () -> ()>, %none2 : $Optional<@callee_guaranteed () -> ()>)

bb3(%phi1 : @owned $Optional<@callee_guaranteed () -> ()>, %phi2 : $Optional<@callee_guaranteed () -> ()>):
  destroy_value %phi1 : $Optional<@callee_guaranteed () -> ()>
  %r = tuple ()
  return %r : $()
}

// Same as above but with phi positions swapped: phi1 is @none and phi2 is
// @owned. Covers the symmetric case.
//
// CHECK-LABEL: sil [ossa] @none_phi_before_owned_phi_from_forwarding_enum :
// CHECK: bb3([[A:%.*]] : $Optional<@callee_guaranteed () -> ()>):
// CHECK-LABEL: } // end sil function 'none_phi_before_owned_phi_from_forwarding_enum'
sil [ossa] @none_phi_before_owned_phi_from_forwarding_enum : $@convention(thin) () -> () {
bb0:
  %fn = function_ref @callee : $@convention(thin) () -> ()
  %thick = thin_to_thick_function %fn to $@callee_guaranteed () -> ()
  cond_br undef, bb1, bb2

bb1:
  %some_none = enum $Optional<@callee_guaranteed () -> ()>, #Optional.some!enumelt, %thick
  %some_owned = enum $Optional<@callee_guaranteed () -> ()>, #Optional.some!enumelt, %thick, forwarding: @owned
  br bb3(%some_none : $Optional<@callee_guaranteed () -> ()>, %some_owned : $Optional<@callee_guaranteed () -> ()>)

bb2:
  %none1 = enum $Optional<@callee_guaranteed () -> ()>, #Optional.none!enumelt
  %none2 = enum $Optional<@callee_guaranteed () -> ()>, #Optional.none!enumelt
  br bb3(%none1 : $Optional<@callee_guaranteed () -> ()>, %none2 : $Optional<@callee_guaranteed () -> ()>)

bb3(%phi1 : $Optional<@callee_guaranteed () -> ()>, %phi2 : @owned $Optional<@callee_guaranteed () -> ()>):
  destroy_value %phi2 : $Optional<@callee_guaranteed () -> ()>
  %r = tuple ()
  return %r : $()
}

// CHECK-LABEL: sil [ossa] @mixed_forwarding_across_preds :
// CHECK: bb3([[A:%.*]] : $Optional<@callee_guaranteed () -> ()>):
// CHECK-LABEL: } // end sil function 'mixed_forwarding_across_preds'
sil [ossa] @mixed_forwarding_across_preds : $@convention(thin) () -> () {
bb0:
  %fn = function_ref @callee : $@convention(thin) () -> ()
  %thick = thin_to_thick_function %fn to $@callee_guaranteed () -> ()
  cond_br undef, bb1, bb2

bb1:
  %some_owned = enum $Optional<@callee_guaranteed () -> ()>, #Optional.some!enumelt, %thick, forwarding: @owned
  %some_none1 = enum $Optional<@callee_guaranteed () -> ()>, #Optional.some!enumelt, %thick
  br bb3(%some_owned : $Optional<@callee_guaranteed () -> ()>, %some_none1 : $Optional<@callee_guaranteed () -> ()>)

bb2:
  %some_none2 = enum $Optional<@callee_guaranteed () -> ()>, #Optional.some!enumelt, %thick
  %some_none3 = enum $Optional<@callee_guaranteed () -> ()>, #Optional.some!enumelt, %thick
  br bb3(%some_none2 : $Optional<@callee_guaranteed () -> ()>, %some_none3 : $Optional<@callee_guaranteed () -> ()>)

bb3(%phi1 : @owned $Optional<@callee_guaranteed () -> ()>, %phi2 : $Optional<@callee_guaranteed () -> ()>):
  destroy_value %phi1 : $Optional<@callee_guaranteed () -> ()>
  %r = tuple ()
  return %r : $()
}

