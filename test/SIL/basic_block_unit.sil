// CHECK-LABEL: begin running test 1 of 1 on overflow_small_custom_bits: instruction_index with: 
// CHECK-NEXT:  #8:   %0 = integer_literal $Builtin.Int64, 0
// CHECK-NEXT:  #16:   %1 = integer_literal $Builtin.Int64, 1
// CHECK:       #80008:   %10000 = string_literal utf8 "insert 10000"
// CHECK-NEXT:  #80016:   %10001 = string_literal utf8 "renumber"
// CHECK-NEXT:  #80024:   %10002 = tuple ()
// CHECK-NEXT:  #80032:   return %10002 : $()
// CHECK-NEXT:  end running test 1 of 1 on overflow_small_custom_bits: instruction_index with: 
sil @overflow_small_custom_bits : $@convention(thin) () -> () {
bb0:
  specify_test "instruction_index"
  %1 = string_literal utf8 "insert 10000"
  %2 = string_literal utf8 "renumber"
  %3 = tuple ()
  return %3
}

