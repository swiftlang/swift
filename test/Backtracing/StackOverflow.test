// The exact number of recursion frames varies from platform to platform;
// on macOS, there is a hidden dyld frame at the very top, which takes up one
// of the 16 frames.  On Linux, we may have a couple of libc frames as well.

// CHECK: {{[0-9]+}} [ra]          0x{{[0-9a-f]+}} static StackOverflow.main() + {{[0-9]+}} in stack-overflow.exe at {{.*[\\/]}}StackOverflow.swift:11:5
// CHECK-NEXT: {{[0-9]+}} [ra] [system] 0x{{[0-9a-f]+}} static StackOverflow.$main() + {{[0-9]+}} in stack-overflow.exe at {{.*[\\/]}}<compiler-generated>
// CHECK-NEXT: {{[0-9]+}} [ra] [system] 0x{{[0-9a-f]+}} main + {{[0-9]+}} in stack-overflow.exe at {{.*[\\/]}}StackOverflow.swift

