// RUN: %target-sil-opt -sil-print-types %s -sil-combine -sil-print-debuginfo | %FileCheck %s

// Test salvaging of struct_extract, tuple_extract, unchecked_enum_data,
// destructure_struct, and destructure_tuple instructions into debug
// reconstruction blocks.

sil_stage canonical

import Builtin
import Swift

struct TwoFields {
  @_hasStorage var x: Int64 { get set }
  @_hasStorage var y: Int64 { get set }
}

sil_scope 1 { loc "test.swift":1:1 parent @test_struct_extract : $@convention(thin) (Int64) -> () }
sil_scope 2 { loc "test.swift":10:1 parent @test_tuple_extract : $@convention(thin) ((Builtin.Int64, Builtin.Int64)) -> () }
sil_scope 3 { loc "test.swift":20:1 parent @test_destructure_struct : $@convention(thin) (TwoFields) -> () }
sil_scope 4 { loc "test.swift":30:1 parent @test_destructure_tuple : $@convention(thin) ((Builtin.Int64, Builtin.Int64)) -> () }
sil_scope 5 { loc "test.swift":40:1 parent @test_fragment_and_debugbb : $@convention(thin) ((Builtin.Int64, Builtin.Int64)) -> () }
sil_scope 6 { loc "test.swift":50:1 parent @test_unchecked_enum_data : $@convention(thin) (Optional<Builtin.Int64>) -> () }

// CHECK-LABEL: sil @test_struct_extract
// CHECK:       bb0([[VAL:%[0-9]+]] : $Int64):
// CHECK:         debug_value [[VAL]] : $Int64, let, name "x", {{.*}}transform {
// CHECK:           bb0([[ARG:%[0-9]+]] : $Int64):
// CHECK:             [[SE:%[0-9]+]] = struct_extract [[ARG]] : $Int64, #Int64._value
// CHECK:             return [[SE]] : $Builtin.Int64
// CHECK:         }
// CHECK:         return
// CHECK-LABEL: } // end sil function 'test_struct_extract'
sil @test_struct_extract : $@convention(thin) (Int64) -> () {
bb0(%0 : $Int64):
  %1 = struct_extract %0 : $Int64, #Int64._value
  debug_value %1 : $Builtin.Int64, let, name "x", loc "test.swift":1:1, scope 1
  %t = tuple ()
  return %t : $()
}

// CHECK-LABEL: sil @test_tuple_extract
// CHECK:       bb0([[TUP:%[0-9]+]] : $(Builtin.Int64, Builtin.Int64)):
// CHECK:         debug_value [[TUP]] : $(Builtin.Int64, Builtin.Int64), let, name "first", {{.*}}transform {
// CHECK:           bb0([[ARG:%[0-9]+]] : $(Builtin.Int64, Builtin.Int64)):
// CHECK:             [[TE:%[0-9]+]] = tuple_extract [[ARG]] : $(Builtin.Int64, Builtin.Int64), 0
// CHECK:             return [[TE]] : $Builtin.Int64
// CHECK:         }
// CHECK:         return
// CHECK-LABEL: } // end sil function 'test_tuple_extract'
sil @test_tuple_extract : $@convention(thin) ((Builtin.Int64, Builtin.Int64)) -> () {
bb0(%0 : $(Builtin.Int64, Builtin.Int64)):
  %1 = tuple_extract %0 : $(Builtin.Int64, Builtin.Int64), 0
  debug_value %1 : $Builtin.Int64, let, name "first", loc "test.swift":10:1, scope 2
  %t = tuple ()
  return %t : $()
}

// destructure_struct is salvaged using struct_extract.

// CHECK-LABEL: sil @test_destructure_struct
// CHECK:       bb0([[VAL:%[0-9]+]] : $TwoFields):
// CHECK:         debug_value [[VAL]] : $TwoFields, let, name "a", {{.*}}transform {
// CHECK:           bb0([[ARG:%[0-9]+]] : $TwoFields):
// CHECK:             [[SE:%[0-9]+]] = struct_extract [[ARG]] : $TwoFields, #TwoFields.x
// CHECK:             return [[SE]] : $Int64
// CHECK:         }
// CHECK:         debug_value [[VAL]] : $TwoFields, let, name "b", {{.*}}transform {
// CHECK:           bb0([[ARG2:%[0-9]+]] : $TwoFields):
// CHECK:             [[SE2:%[0-9]+]] = struct_extract [[ARG2]] : $TwoFields, #TwoFields.y
// CHECK:             return [[SE2]] : $Int64
// CHECK:         }
// CHECK:         return
// CHECK-LABEL: } // end sil function 'test_destructure_struct'
sil @test_destructure_struct : $@convention(thin) (TwoFields) -> () {
bb0(%0 : $TwoFields):
  (%1, %2) = destructure_struct %0 : $TwoFields
  debug_value %1 : $Int64, let, name "a", loc "test.swift":20:1, scope 3
  debug_value %2 : $Int64, let, name "b", loc "test.swift":21:1, scope 3
  %t = tuple ()
  return %t : $()
}

// destructure_tuple is salvaged using tuple_extract.

// CHECK-LABEL: sil @test_destructure_tuple
// CHECK:       bb0([[TUP:%[0-9]+]] : $(Builtin.Int64, Builtin.Int64)):
// CHECK:         debug_value [[TUP]] : $(Builtin.Int64, Builtin.Int64), let, name "first", {{.*}}transform {
// CHECK:           bb0([[ARG:%[0-9]+]] : $(Builtin.Int64, Builtin.Int64)):
// CHECK:             [[TE:%[0-9]+]] = tuple_extract [[ARG]] : $(Builtin.Int64, Builtin.Int64), 0
// CHECK:             return [[TE]] : $Builtin.Int64
// CHECK:         }
// CHECK:         debug_value [[TUP]] : $(Builtin.Int64, Builtin.Int64), let, name "second", {{.*}}transform {
// CHECK:           bb0([[ARG2:%[0-9]+]] : $(Builtin.Int64, Builtin.Int64)):
// CHECK:             [[TE2:%[0-9]+]] = tuple_extract [[ARG2]] : $(Builtin.Int64, Builtin.Int64), 1
// CHECK:             return [[TE2]] : $Builtin.Int64
// CHECK:         }
// CHECK:         return
// CHECK-LABEL: } // end sil function 'test_destructure_tuple'
sil @test_destructure_tuple : $@convention(thin) ((Builtin.Int64, Builtin.Int64)) -> () {
bb0(%0 : $(Builtin.Int64, Builtin.Int64)):
  (%1, %2) = destructure_tuple %0 : $(Builtin.Int64, Builtin.Int64)
  debug_value %1 : $Builtin.Int64, let, name "first", loc "test.swift":30:1, scope 4
  debug_value %2 : $Builtin.Int64, let, name "second", loc "test.swift":31:1, scope 4
  %t = tuple ()
  return %t : $()
}

// Cascading salvage: tuple salvage creates fragments pointing at
// tuple_extract results, then tuple_extracts salvage creates debug BBs.

// CHECK-LABEL: sil @test_fragment_and_debugbb
// CHECK:       bb0([[TUP:%[0-9]+]] : $(Builtin.Int64, Builtin.Int64)):
// CHECK:         debug_value [[TUP]] : $(Builtin.Int64, Builtin.Int64), let, name "copy", type $(Builtin.Int64, Builtin.Int64), expr op_tuple_fragment:$(Builtin.Int64, Builtin.Int64):0, {{.*}}transform {
// CHECK:           bb0([[ARG:%[0-9]+]] : $(Builtin.Int64, Builtin.Int64)):
// CHECK:             [[TE:%[0-9]+]] = tuple_extract [[ARG]] : $(Builtin.Int64, Builtin.Int64), 0
// CHECK:             return [[TE]] : $Builtin.Int64
// CHECK:         }
// CHECK:         debug_value [[TUP]] : $(Builtin.Int64, Builtin.Int64), let, name "copy", type $(Builtin.Int64, Builtin.Int64), expr op_tuple_fragment:$(Builtin.Int64, Builtin.Int64):1, {{.*}}transform {
// CHECK:           bb0([[ARG2:%[0-9]+]] : $(Builtin.Int64, Builtin.Int64)):
// CHECK:             [[TE2:%[0-9]+]] = tuple_extract [[ARG2]] : $(Builtin.Int64, Builtin.Int64), 1
// CHECK:             return [[TE2]] : $Builtin.Int64
// CHECK:         }
// CHECK:         return
// CHECK-LABEL: } // end sil function 'test_fragment_and_debugbb'
sil @test_fragment_and_debugbb : $@convention(thin) ((Builtin.Int64, Builtin.Int64)) -> () {
bb0(%0 : $(Builtin.Int64, Builtin.Int64)):
  %1 = tuple_extract %0 : $(Builtin.Int64, Builtin.Int64), 0
  %2 = tuple_extract %0 : $(Builtin.Int64, Builtin.Int64), 1
  %3 = tuple (%1 : $Builtin.Int64, %2 : $Builtin.Int64)
  debug_value %3 : $(Builtin.Int64, Builtin.Int64), let, name "copy", loc "test.swift":40:1, scope 5
  %t = tuple ()
  return %t : $()
}

// CHECK-LABEL: sil @test_unchecked_enum_data
// CHECK:       bb0(%0 : $Optional<Builtin.Int64>):
// CHECK:         debug_value %0 : $Optional<Builtin.Int64>, let, name "payload", {{.*}}transform {
// CHECK:           bb0(%0 : $Optional<Builtin.Int64>):
// CHECK:             %1 = unchecked_enum_data %0 : $Optional<Builtin.Int64>, #Optional.some!enumelt
// CHECK:             return %1 : $Builtin.Int64
// CHECK:         }
// CHECK:         return
// CHECK-LABEL: } // end sil function 'test_unchecked_enum_data'
sil @test_unchecked_enum_data : $@convention(thin) (Optional<Builtin.Int64>) -> () {
bb0(%0 : $Optional<Builtin.Int64>):
  %1 = unchecked_enum_data %0 : $Optional<Builtin.Int64>, #Optional.some!enumelt
  debug_value %1 : $Builtin.Int64, let, name "payload", loc "test.swift":50:1, scope 6
  %t = tuple ()
  return %t : $()
}
