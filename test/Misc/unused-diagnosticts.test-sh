# RUN: %empty-directory(%t)
# RUN: split-file %s %t
# RUN: cd %swift_src_root
# RUN: %utils/find-unused-diagnostics.sh > %t/unused.txt
# RUN: %diff %t/unused.txt %t/unused.expected

# If you broke this test you likely removed the last use of a
# diagnostic, without removing the diagnostic. If this was a
# false positive, add the diagnostic name to the list below.

# UNSUPPORTED: OS=windows-msvc

