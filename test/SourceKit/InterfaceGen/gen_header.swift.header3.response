public enum SKFuelKind : CUnsignedInt {

    case H2 = 0

    case CH4 = 1

    case C12H26 = 2
}
extension SKFuelKind {

    public var isCryogenic: CUnsignedInt { get }

    public var isNotCryogenic: CUnsignedInt { get }
}

